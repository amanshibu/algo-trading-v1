# ============================================================
# Algo Trading Platform — Environment Configuration Template
# Copy this to .env and fill in your values.
# ============================================================

ENV=development

# AngelOne SmartAPI (get from https://smartapi.angelone.in/)
ANGELONE_API_KEY=your_api_key_here
ANGELONE_CLIENT_ID=your_client_id_here
ANGELONE_PIN=your_4digit_pin_here
ANGELONE_TOTP_SECRET=your_totp_secret_here

# App
SECRET_KEY=change-me-in-production
